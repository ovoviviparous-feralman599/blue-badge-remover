{
  "name": "blue-badge-remover",
  "version": "1.3.1",
  "description": "X(트위터)에서 수익성 목적의 파란 뱃지 계정을 숨기는 크롬 익스텐션. 팔로우 중인 계정과 수동 화이트리스트는 예외 처리.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:edge": "wxt build --browser edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "zip:edge": "wxt zip --browser edge",
    "submit": "wxt submit --chrome-zip .output/chrome-mv3.zip --firefox-zip .output/firefox-mv2.zip --edge-zip .output/edge-mv3.zip",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.38",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wxt": "^0.20.20"
  }
}
